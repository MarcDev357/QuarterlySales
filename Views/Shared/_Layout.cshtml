<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Quarterly Sales</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">Home</a>

            <div class="navbar-nav me-auto">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a class="nav-link" asp-controller="Sales" asp-action="Add">Add Sales</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a class="nav-link" asp-controller="Employee" asp-action="Add">Add Employee</a>
                    }
                }
            </div>

            <div class="navbar-nav ms-auto">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <span class="nav-link">Welcome, @User.Identity.Name!</span>

                    @if (User.IsInRole("Admin"))
                    {
                        <a class="nav-link" asp-controller="User" asp-action="Index">Manage Users</a>
                    }

                    <form method="post"
                          asp-area="Identity"
                          asp-page="/Account/Logout"
                          asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                          class="d-inline">
                        <button type="submit" class="btn btn-link nav-link" style="text-decoration:none;">Log Out</button>
                    </form>
                }
                else
                {
                    <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">Register</a>
                    <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Log In</a>
                }
            </div>
        </div>
    </nav>

    <div class="container">
        <h1>Quarterly Sales</h1>
        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>